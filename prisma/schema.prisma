generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

//////////////////// ENUMS ////////////////////

enum Role {
  STUDENT
  ADMIN
}

enum SellerTier {
  BASIC
  VERIFIED
  PREMIUM
}

enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

//////////////////// USER ////////////////////

model User {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String?
  email          String?  @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  role           Role     @default(STUDENT)

  sellerTier     SellerTier @default(BASIC)

  accounts       Account[]
  sessions       Session[]

  products       Product[]
  orders         Order[]
  reviews        Review[]
  wishlist       Wishlist[]

  cart           Cart[]

  sellerWallet   SellerWallet?
  walletTxns     WalletTransaction[]
  payouts        Payout[]
}

//////////////////// NEXTAUTH MODELS ////////////////////

model Account {
  id                 String  @id @default(auto()) @map("_id") @db.ObjectId
  userId             String  @db.ObjectId
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

//////////////////// CATEGORY ////////////////////

model Category {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String    @unique
  description String?
  isActive    Boolean   @default(true)

  products    Product[]

  createdAt   DateTime  @default(now())
}

//////////////////// PRODUCT ////////////////////

model Product {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  price       Float
  images      String[]
  stock       Int
  rating      Float         @default(0)
  status      ProductStatus @default(PENDING)

  sellerId    String        @db.ObjectId
  seller      User          @relation(fields: [sellerId], references: [id])

  categoryId  String        @db.ObjectId
  category    Category      @relation(fields: [categoryId], references: [id])

  reviews     Review[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  wishlists   Wishlist[]
}

//////////////////// CART ////////////////////

model Cart {
  id       String     @id @default(auto()) @map("_id") @db.ObjectId
  userId   String     @db.ObjectId
  user     User       @relation(fields: [userId], references: [id])
  items    CartItem[]
}

model CartItem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  cartId    String   @db.ObjectId
  productId String   @db.ObjectId
  quantity  Int

  cart      Cart     @relation(fields: [cartId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

//////////////////// ORDER ////////////////////

model Order {
  id         String       @id @default(auto()) @map("_id") @db.ObjectId
  userId     String       @db.ObjectId
  user       User         @relation(fields: [userId], references: [id])

  status     OrderStatus  @default(PENDING)
  total      Float

  paymentId     String?
  paymentStatus String?   @default("PENDING")

  createdAt  DateTime     @default(now())

  items      OrderItem[]
}

model OrderItem {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  orderId       String   @db.ObjectId
  productId     String   @db.ObjectId
  quantity      Int
  price         Float

  commission    Float
  sellerRevenue Float

  order     Order    @relation(fields: [orderId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

//////////////////// SELLER WALLET ////////////////////

model SellerWallet {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  sellerId  String   @unique @db.ObjectId
  balance   Float    @default(0)

  seller    User     @relation(fields: [sellerId], references: [id])

  createdAt DateTime @default(now())
}

model WalletTransaction {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  sellerId  String   @db.ObjectId
  orderId   String   @db.ObjectId
  amount    Float
  type      String
  createdAt DateTime @default(now())

  seller    User     @relation(fields: [sellerId], references: [id])
}

//////////////////// PAYOUT ////////////////////

model Payout {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  sellerId  String   @db.ObjectId
  amount    Float
  status    String
  createdAt DateTime @default(now())

  seller    User     @relation(fields: [sellerId], references: [id])
}

//////////////////// REVIEW ////////////////////

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  rating    Int
  comment   String
  images    String[]
  createdAt DateTime @default(now())

  userId    String   @db.ObjectId
  productId String   @db.ObjectId

  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

//////////////////// WISHLIST ////////////////////

model Wishlist {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  productId String   @db.ObjectId

  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

//////////////////// DELIVERY ////////////////////

model DeliveryZone {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  codAvailable      Boolean @default(true)
  deliveryAvailable Boolean @default(true)
  deliveryDays      Int
}

model PincodeZone {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  pincode String @unique
  zoneId  String
}

//////////////////// CHECKOUT SYSTEM ////////////////////

model CheckoutSession {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  total     Float
  status    String
  createdAt DateTime @default(now())
}

model StockReservation {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  productId         String   @db.ObjectId
  userId            String   @db.ObjectId
  quantity          Int

  checkoutSessionId String?  @db.ObjectId

  status            ReservationStatus @default(ACTIVE)

  expiresAt         DateTime
  createdAt         DateTime @default(now())
}

enum ReservationStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}
 